local physicsConnection = nil

local function TogglePhysicsOverrides(state)
    if state then
        if not physicsConnection then
            physicsConnection = RunService.Stepped:Connect(function()
                local char = LocalPlayer.Character
                if char then
                    local hrp = char:FindFirstChild("HumanoidRootPart")
                    if hrp and not hrp:FindFirstChild("AutofarmFloat") then
                        local bv = Instance.new("BodyVelocity")
                        bv.Name = "AutofarmFloat"
                        bv.MaxForce = Vector3.new(9e9, 9e9, 9e9) 
                        bv.Velocity = Vector3.new(0, 0, 0)       
                        bv.Parent = hrp
                    end
                    for _, part in ipairs(char:GetDescendants()) do
                        if part:IsA("BasePart") and part.CanCollide then
                            part.CanCollide = false
                        end
                    end
                end
            end)
        end
    else
        if physicsConnection then
            physicsConnection:Disconnect()
            physicsConnection = nil
        end
        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if hrp then
            local floatForce = hrp:FindFirstChild("AutofarmFloat")
            if floatForce then floatForce:Destroy() end
        end
    end
end

