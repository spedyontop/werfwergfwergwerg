local function ExploitPrompt(prompt)
    if not prompt or getgenv().IsAborting then return end 
    pcall(function()
        prompt.RequiresLineOfSight = false
        prompt.MaxActivationDistance = 9e9
        if fireproximityprompt then
            fireproximityprompt(prompt)
        else
            prompt:InputHoldBegin()
            task.wait(0.05)
            prompt:InputHoldEnd()
        end
    end)
end

-- ==========================================
-- LOOTING SYSTEM (MAGNETIZED)
-- ==========================================
local function DoLooting()
    UpdateStatus("Waiting for Event Chest...")
    local chest = Interactables:WaitForChild("Event Chest", 15)
    
    if not chest then
        UpdateStatus("No chest spawned.")
        return
    end

    -- MAGNETIZE CHEST TO PLAYER
    BringAndFreeze(chest)

    local chestPrompt = nil
    repeat
        task.wait(0.1)
        chestPrompt = chest:FindFirstChildWhichIsA("ProximityPrompt", true)
    until chestPrompt or not chest.Parent or getgenv().IsAborting
    
    if getgenv().IsAborting or not chest.Parent then return end

    local droppedLoot = {}
    local dropConnection = Interactables.ChildAdded:Connect(function(child)
        if child.Name ~= "Event Chest" then
            table.insert(droppedLoot, child)
            -- MAGNETIZE EACH ITEM AS IT DROPS
            task.spawn(function()
                task.wait(0.1) 
                BringAndFreeze(child)
            end)
        end
    end)

    local chestTimeout = os.clock() + 8 
    local lastLootCount = 0
    local idleTime = 0

    UpdateStatus("Opening Chest...")

    while os.clock() < chestTimeout and getgenv().AutoBounty and not getgenv().IsAborting do
        ExploitPrompt(chestPrompt)
        
        if #droppedLoot > 0 then
            if #droppedLoot == lastLootCount then
                idleTime = idleTime + 0.1
                if idleTime >= 1.5 then break end
            else
                lastLootCount = #droppedLoot
                idleTime = 0
            end
        end
        task.wait(0.1)
    end

    dropConnection:Disconnect()
    if getgenv().IsAborting then return end

    if #droppedLoot > 0 then
        UpdateStatus("Vacuuming " .. #droppedLoot .. " items...")
        local firedPrompts = {} 
        local sweepTimeout = os.clock() + 4
        
        while os.clock() < sweepTimeout and not getgenv().IsAborting do
            local itemsRemaining = false
            for _, item in ipairs(droppedLoot) do
                if item.Parent == Interactables then
                    local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
                    if prompt then
                        itemsRemaining = true
                        if not firedPrompts[prompt] then
                            firedPrompts[prompt] = true
                            task.spawn(function()
                                ExploitPrompt(prompt)
                                task.wait(0.5)
                                firedPrompts[prompt] = nil 
                            end)
                        end
                    end
                end
            end
            if not itemsRemaining then break end
            task.wait(0.1) 
        end
    end
    UpdateStatus("Loot secured.")
end

-- ==========================================
-- MAIN AUTOFARM LOGIC
-- ==========================================
local function DoBountyCycle()
    if getgenv().IsAborting then return end

    local targetBounty = (getgenv().FarmMonster and getgenv().FarmWinter) and 
        ((lastBountyDone == "Winter Outbreak") and "Monster Sighting" or "Winter Outbreak") or 
        (getgenv().FarmMonster and "Monster Sighting") or (getgenv().FarmWinter and "Winter Outbreak")
    
    if not targetBounty then UpdateStatus("No bounty selected") task.wait(1) return end
    lastBountyDone = targetBounty

    pcall(function() TakeBountyRemote:FireServer("ClearPVE") end)
    task.wait(0.5)

    UpdateStatus("Accepting: " .. targetBounty)
    pcall(function() TakeBountyRemote:FireServer("PVE", targetBounty) end)
    task.wait(3)
    
    if getgenv().IsAborting then return end

    local targetBoss = nil
    for _, model in ipairs(LiveFolder:GetChildren()) do
        if model:FindFirstChild("BossTag") then targetBoss = model break end
    end

    if not targetBoss then
        local marker = Workspace:WaitForChild("MissionMarker", 3)
        if marker then
            local markerCFrame = marker:IsA("Model") and marker:GetPivot() or marker.CFrame
            if SafeTeleport(markerCFrame) then task.wait(0.5) marker:Destroy() end
        end
        for i = 1, 70 do
            if not getgenv().AutoBounty or getgenv().IsAborting then break end
            for _, model in ipairs(LiveFolder:GetChildren()) do
                if model:FindFirstChild("BossTag") then targetBoss = model break end
            end
            if targetBoss then break end
            task.wait(0.1)
        end
    end

    if targetBoss and not getgenv().IsAborting then
        local bossName = targetBoss.Name:lower() 
        for _, skip in ipairs(getgenv().IgnoredBosses) do
            if skip ~= "" and string.find(bossName, skip:lower()) then
                AbortBounty("Skipped: " .. targetBoss.Name)
                return
            end
        end
        
        UpdateStatus("Fighting " .. targetBoss.Name)
        local combatStart = os.clock()
        
        while targetBoss.Parent == LiveFolder and getgenv().AutoBounty and not getgenv().IsAborting do
            if os.clock() - combatStart >= 60 then AbortBounty("Kill Timeout") return end

            local bossHrp = targetBoss:FindFirstChild("HumanoidRootPart")
            if not bossHrp then task.wait(0.1) continue end

            if string.find(bossName, "minotaur") then
                local hrp = GetHRP()
                if hrp then
                    if not SafeTween(hrp, bossHrp.CFrame * CFrame.new(0, 200, 356.4), 0.5) then break end
                    if targetBoss.Parent == LiveFolder then
                        SafeTween(hrp, bossHrp.CFrame * CFrame.new(0, 0, 10), 0.5)
                        task.wait(3)
                    end
                end
            else
                local desiredCFrame = bossHrp.CFrame * CFrame.new(0, 0, 4)
                local hrp = GetHRP()
                if hrp then
                    if (hrp.Position - desiredCFrame.Position).Magnitude > 15 then
                        SafeTeleport(desiredCFrame)
                    else
                        TweenService:Create(hrp, TweenInfo.new(0.1), {CFrame = desiredCFrame}):Play()
                    end
                end
                task.wait(0.1) 
            end
        end
    end

    if not getgenv().IsAborting then DoLooting() end
    UpdateStatus("Restarting Cycle...")
    task.wait(1)
end

