local function HandleChestExpiration(chest)
    if string.find(chest.Name:lower(), "chest") then
        task.delay(15, function()
            if chest and chest.Parent then
                pcall(function() chest:Destroy() end)
            end
        end)
    end
end

for _, child in ipairs(Interactables:GetChildren()) do
    HandleChestExpiration(child)
end

Interactables.ChildAdded:Connect(HandleChestExpiration)

task.spawn(function()
    while task.wait(0.1) do
