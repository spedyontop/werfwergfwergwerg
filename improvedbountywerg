-- ==========================================
-- HELPER FUNCTIONS
-- ==========================================
local function GetHRP()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function FreezeInPlace(obj)
    if not obj then return end
    pcall(function()
        for _, part in ipairs(obj:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Velocity = Vector3.new(0,0,0)
                part.RotVelocity = Vector3.new(0,0,0)
                part.Anchored = true 
            end
        end
    end)
end

local function BringAndFreeze(obj)
    if not obj then return end
    local hrp = GetHRP()
    if not hrp then return end
    
    pcall(function()
        local targetCF = hrp.CFrame
        
        if obj:IsA("Model") then
            obj:PivotTo(targetCF)
        elseif obj:IsA("BasePart") then
            obj.CFrame = targetCF
            obj.Velocity = Vector3.new(0,0,0)
            obj.RotVelocity = Vector3.new(0,0,0)
            obj.Anchored = true 
        end
        
        for _, part in ipairs(obj:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Velocity = Vector3.new(0,0,0)
                part.RotVelocity = Vector3.new(0,0,0)
                if not obj:IsA("Model") then part.CFrame = targetCF end
                part.Anchored = true 
            end
        end
    end)
end

local function IsPlayerNearPosition(targetPos, radius)
    if radius <= 0 then return false end
    local radSq = radius * radius 
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local targetHrp = p.Character:FindFirstChild("HumanoidRootPart")
            if targetHrp and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
                local dx = targetPos.X - targetHrp.Position.X
                local dz = targetPos.Z - targetHrp.Position.Z
                if (dx * dx + dz * dz) <= radSq then return true end
            end
        end
    end
    return false
end

-- ==========================================
-- EMERGENCY & TELEPORT SYSTEM
-- ==========================================
local function EmergencySkyTP()
    local hrp = GetHRP()
    if hrp then
        hrp.Anchored = true
        hrp.CFrame = CFrame.new(hrp.Position.X, 15000, hrp.Position.Z)
        task.wait(0.1)
        hrp.Anchored = false
    end
end

local function AbortBounty(reason)
    if getgenv().IsAborting then return end
    getgenv().IsAborting = true
    UpdateStatus("Aborting (" .. reason .. ")...")
    EmergencySkyTP()
    pcall(function() TakeBountyRemote:FireServer("ClearPVE") end)
    task.wait(2)
    getgenv().IsAborting = false
end

local function SafeTeleport(cframe)
    if getgenv().IsAborting then return false end
    if getgenv().AntiPlayerRadius > 0 and IsPlayerNearPosition(cframe.Position, getgenv().AntiPlayerRadius) then
        task.spawn(function() AbortBounty("Player at teleport destination") end)
        return false
    end
    local hrp = GetHRP()
    if hrp then hrp.CFrame = cframe return true end
    return false
end

local function SafeTween(hrp, cframe, duration)
    if getgenv().IsAborting then return false end
    if getgenv().AntiPlayerRadius > 0 and IsPlayerNearPosition(cframe.Position, getgenv().AntiPlayerRadius) then
        task.spawn(function() AbortBounty("Player at tween destination") end)
        return false
    end
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(hrp, tweenInfo, {CFrame = cframe})
    tween:Play()
    task.wait(duration)
    return not getgenv().IsAborting
end

local function FirePrompt(prompt)
    if not prompt or getgenv().IsAborting then return end 
    pcall(function()
        if fireproximityprompt then
            fireproximityprompt(prompt)
        else
            prompt:InputHoldBegin()
            task.wait(0.05)
            prompt:InputHoldEnd()
        end
    end)
end

local function SendWebhook(chestNames, itemNames)
    local url = getgenv().WebhookURL
    if not url or url == "" then return end

    local requestFunc = http_request or request or HttpPost or syn.request
    if not requestFunc then return end

    local chestString = #chestNames > 0 and table.concat(chestNames, ", ") or "None"
    local itemString = #itemNames > 0 and table.concat(itemNames, ", ") or "None"

    local data = {
        ["embeds"] = {{
            ["color"] = tonumber(0x58b9ff),
            ["description"] = " **Player:** ||" .. LocalPlayer.Name .. "||\n **Chests:** " .. chestString .. "\n **Loot:** " .. itemString
        }}
    }

    pcall(function()
        requestFunc({
            Url = url,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(data)
        })
    end)
end

-- ==========================================
-- MULTI-CHEST LOOTING (UNIVERSAL & PROXIMITY)
-- ==========================================
local function DoLooting()
    UpdateStatus("Waiting for Chest(s)...")
    
    local hrp = GetHRP()
    if not hrp then return end

    local MAX_DISTANCE = 50 
    local VOID_THRESHOLD = -1500 

    local foundAnyChest = false
    local waitTimeout = os.clock() + 10
    while os.clock() < waitTimeout do
        for _, item in ipairs(Interactables:GetChildren()) do
            if string.find(item.Name:lower(), "chest") then
                local chestPart = item.PrimaryPart or item:FindFirstChildWhichIsA("BasePart")
                if chestPart and (chestPart.Position - hrp.Position).Magnitude <= MAX_DISTANCE then
                    foundAnyChest = true
                    break
                end
            end
        end
        if foundAnyChest then break end
        task.wait(0.25)
    end

    if not foundAnyChest then
        UpdateStatus("No chest spawned.")
        return
    end

    local activeChests = {}

    for _, item in ipairs(Interactables:GetChildren()) do
        if string.find(item.Name:lower(), "chest") then
            local chestPart = item.PrimaryPart or item:FindFirstChildWhichIsA("BasePart")
            if chestPart then
                if chestPart.Position.Y < VOID_THRESHOLD then
                    item:Destroy()
                elseif (chestPart.Position - hrp.Position).Magnitude <= MAX_DISTANCE then
                    table.insert(activeChests, item)
                    FreezeInPlace(item) 
                end
            end
        end
    end

    if #activeChests == 0 then
        UpdateStatus("No valid chests found nearby.")
        return
    end

    UpdateStatus("Looting " .. #activeChests .. " Chest(s)...")

    local droppedLoot = {}
    local itemsSpawned = 0
    local lastDropTime = os.clock() 

    local dropConnection = Interactables.ChildAdded:Connect(function(child)
        if not string.find(child.Name:lower(), "chest") then
            table.insert(droppedLoot, child)
            itemsSpawned = itemsSpawned + 1
            lastDropTime = os.clock() 
            task.spawn(function()
                task.wait() 
                BringAndFreeze(child)
            end)
        end
    end)

    for _, chest in ipairs(activeChests) do
        if getgenv().IsAborting then break end
        
        local chestPart = chest.PrimaryPart or chest:FindFirstChildWhichIsA("BasePart")
        if chestPart and hrp then
            SafeTeleport(chestPart.CFrame * CFrame.new(0, 3, 0))
        end
        
        local chestTimeout = os.clock() + 3
        while os.clock() < chestTimeout and chest.Parent do
            local prompt = chest:FindFirstChildWhichIsA("ProximityPrompt", true)
            if prompt and prompt.Enabled then
                FirePrompt(prompt)
            else
                break 
            end
            task.wait(0.1)
        end
    end

    local vacuumTimeout = os.clock() + 5 
    while os.clock() < vacuumTimeout and getgenv().AutoBounty and not getgenv().IsAborting do
        
        for _, item in ipairs(droppedLoot) do
            if item.Parent == Interactables then
                local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
                if prompt and prompt.Enabled then
                    FirePrompt(prompt)
                end
            end
        end
        
        if itemsSpawned > 0 and (os.clock() - lastDropTime > 0.5) then
            break 
        end
        
        if itemsSpawned == 0 and (os.clock() - (vacuumTimeout - 5) > 2.5) then
            break
        end
        
        task.wait(0.05) 
    end

    dropConnection:Disconnect()

    if not getgenv().IsAborting then
        local loggedChests = {}
        for _, c in ipairs(activeChests) do
            table.insert(loggedChests, c.Name)
        end

        local loggedItems = {}
        for _, i in ipairs(droppedLoot) do
            table.insert(loggedItems, i.Name)
        end

        task.spawn(function() SendWebhook(loggedChests, loggedItems) end)
    end

    if getgenv().IsAborting then return end

    UpdateStatus("Loot secured.")
end

-- ==========================================
-- MAIN AUTOFARM LOGIC
-- ==========================================
local function DoBountyCycle()
    if getgenv().IsAborting then return end

    local targetBounty = (getgenv().FarmMonster and getgenv().FarmWinter) and 
        ((lastBountyDone == "Winter Outbreak") and "Monster Sighting" or "Winter Outbreak") or 
        (getgenv().FarmMonster and "Monster Sighting") or (getgenv().FarmWinter and "Winter Outbreak")
    
    if not targetBounty then UpdateStatus("No bounty selected") task.wait(1) return end
    lastBountyDone = targetBounty

    pcall(function() TakeBountyRemote:FireServer("ClearPVE") end)
    task.wait(0.5)

    UpdateStatus("Accepting: " .. targetBounty)
    pcall(function() TakeBountyRemote:FireServer("PVE", targetBounty) end)
    task.wait(3)
    
    if getgenv().IsAborting then return end

    local targetBoss = nil
    for _, model in ipairs(LiveFolder:GetChildren()) do
        if model:FindFirstChild("BossTag") then targetBoss = model break end
    end

    if not targetBoss then
        UpdateStatus("Going to Marker...")
        
        local marker = Workspace:WaitForChild("MissionMarker", 3)
        
        local markers = {}
        for _, obj in ipairs(Workspace:GetChildren()) do
            if obj.Name == "MissionMarker" then
                table.insert(markers, obj)
            end
        end
        
        if #markers > 1 then
            UpdateStatus("Multiple markers detected! Clearing and restarting...")
            for _, m in ipairs(markers) do
                pcall(function() m:Destroy() end)
            end
            pcall(function() TakeBountyRemote:FireServer("ClearPVE") end)
            task.wait(1)
            return
        elseif marker then
            local markerCFrame = marker:IsA("Model") and marker:GetPivot() or marker.CFrame
            if SafeTeleport(markerCFrame * CFrame.new(0, -50, 0)) then 
                task.wait(0.5) 
                pcall(function() marker:Destroy() end) 
            end
        end

        for i = 1, 70 do
            if not getgenv().AutoBounty or getgenv().IsAborting then break end
            for _, model in ipairs(LiveFolder:GetChildren()) do
                if model:FindFirstChild("BossTag") then targetBoss = model break end
            end
            if targetBoss then break end
            task.wait(0.1)
        end
    end

    if targetBoss and not getgenv().IsAborting then
        local bossName = targetBoss.Name:lower() 
        for _, skip in ipairs(getgenv().IgnoredBosses) do
            if skip ~= "" and string.find(bossName, skip:lower()) then
                AbortBounty("Skipped: " .. targetBoss.Name)
                return
            end
        end
        
        UpdateStatus("Fighting " .. targetBoss.Name)
        local combatStart = os.clock()
        
        while targetBoss.Parent == LiveFolder and getgenv().AutoBounty and not getgenv().IsAborting do
            if os.clock() - combatStart >= 60 then AbortBounty("Kill Timeout") return end

            local bossHrp = targetBoss:FindFirstChild("HumanoidRootPart")
            if not bossHrp then task.wait(0.1) continue end

            if string.find(bossName, "minotaur") then
                local hrp = GetHRP()
                if hrp then
                    local retreatCF = bossHrp.CFrame * CFrame.new(0, 0, 400)
                    if not SafeTween(hrp, retreatCF, 0.75) then break end
                    
                    if targetBoss.Parent == LiveFolder then
                        local attackCF = bossHrp.CFrame * CFrame.new(0, 0, 10)
                        if not SafeTween(hrp, attackCF, 0.75) then break end
                        
                        task.wait(2) 
                    end
                end
            else
                local desiredCFrame = bossHrp.CFrame * CFrame.new(0, 0, 4)
                local hrp = GetHRP()
                if hrp then
                    if (hrp.Position - desiredCFrame.Position).Magnitude > 15 then
                        SafeTeleport(desiredCFrame)
                    else
                        TweenService:Create(hrp, TweenInfo.new(0.1), {CFrame = desiredCFrame}):Play()
                    end
                end
                task.wait(0.1) 
            end
        end
    end

    if not getgenv().IsAborting then DoLooting() end
    UpdateStatus("Restarting Cycle...")
    task.wait(0.5)
end

