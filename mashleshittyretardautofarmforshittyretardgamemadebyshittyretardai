local function CreateMiniToggle(parent, posY, title, stateKey)
    local Frame = Instance.new("Frame", parent)
    Frame.Size = UDim2.new(1, 0, 0, 30)
    Frame.Position = UDim2.new(0, 0, 0, posY)
    Frame.BackgroundTransparency = 1
    
    local Label = Instance.new("TextLabel", Frame)
    Label.Size = UDim2.new(1, -50, 1, 0)
    Label.BackgroundTransparency = 1
    Label.Text = title
    Label.TextColor3 = THEME.TextMain
    Label.Font = Enum.Font.GothamMedium
    Label.TextSize = 13
    Label.TextXAlignment = Enum.TextXAlignment.Left
    
    local TBg = Instance.new("Frame", Frame)
    TBg.Size = UDim2.new(0, 40, 0, 20)
    TBg.Position = UDim2.new(1, -40, 0.5, -10)
    TBg.BackgroundColor3 = THEME.CardBg
    Instance.new("UICorner", TBg).CornerRadius = UDim.new(1, 0)
    local TStroke = Instance.new("UIStroke", TBg)
    TStroke.Color = THEME.Border
    
    local TKnob = Instance.new("Frame", TBg)
    TKnob.Size = UDim2.new(0, 14, 0, 14)
    TKnob.Position = UDim2.new(0, 3, 0.5, -7)
    TKnob.BackgroundColor3 = THEME.TextMuted
    Instance.new("UICorner", TKnob).CornerRadius = UDim.new(1, 0)
    
    local Btn = Instance.new("TextButton", TBg)
    Btn.Size = UDim2.new(1, 0, 1, 0)
    Btn.BackgroundTransparency = 1
    Btn.Text = ""
    
    Btn.MouseButton1Click:Connect(function()
        States[stateKey] = not States[stateKey]
        local tInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        if States[stateKey] then
            TweenService:Create(TKnob, tInfo, {Position = UDim2.new(1, -17, 0.5, -7), BackgroundColor3 = THEME.TextMain}):Play()
            TweenService:Create(TBg, tInfo, {BackgroundColor3 = THEME.AccentDim}):Play()
            TweenService:Create(TStroke, tInfo, {Color = THEME.Accent}):Play()
        else
            TweenService:Create(TKnob, tInfo, {Position = UDim2.new(0, 3, 0.5, -7), BackgroundColor3 = THEME.TextMuted}):Play()
            TweenService:Create(TBg, tInfo, {BackgroundColor3 = THEME.CardBg}):Play()
            TweenService:Create(TStroke, tInfo, {Color = THEME.Border}):Play()
        end
    end)
