local function hasBountyPoster(char)
    local backpack = player:FindFirstChild("Backpack")
    return (backpack and backpack:FindFirstChild("Bounty Poster")) or (char and char:FindFirstChild("Bounty Poster"))
end

local function getLocalEventChest(root)
    for _, obj in ipairs(workspace.Interactables:GetChildren()) do
        if obj.Name == "Event Chest" and (obj:GetPivot().Position - root.Position).Magnitude <= CHEST_MAX_DISTANCE then return obj end
    end
    return nil
end

local function handleDroppedLoot(root, humanoid)
    local foundLoot = false
    for _, obj in ipairs(workspace.Interactables:GetChildren()) do
        if obj:FindFirstChild("LootAppear") or obj:FindFirstChild("LootTween") then
            local prompt = obj:FindFirstChildWhichIsA("ProximityPrompt", true)
            if prompt and prompt.Enabled then
                foundLoot = true
                local origin = prompt.Parent:IsA("Attachment") and prompt.Parent.WorldPosition or prompt.Parent.Position
                if (root.Position - origin).Magnitude > prompt.MaxActivationDistance then
                    root.Anchored = false
                    root.CFrame = CFrame.new(origin + Vector3.new(0, 1.5, 0))
                    humanoid:ChangeState(Enum.HumanoidStateType.RunningNoPhysics)
                    task.wait(0.2) 
                end
                while prompt and prompt.Parent and prompt.Enabled do
                    if fireproximityprompt then fireproximityprompt(prompt) end
                    task.wait(0.05) 
                end
            end
        end
    end
    return foundLoot
end

local wasPosterActive = false
local phase4Timeout = 0 

task.spawn(function()
    while task.wait(0.1) do
        if not States.Farming then wasPosterActive = false; phase4Timeout = 0; continue end

        local char = player.Character
        if not char then continue end
        local root = char:FindFirstChild("HumanoidRootPart")
        local humanoid = char:FindFirstChild("Humanoid")
        if not root or not humanoid then continue end

        humanoid:SetStateEnabled(Enum.HumanoidStateType.Freefall, false)
        humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
        humanoid.StateChanged:Connect(function(_, newState)
            if (newState == Enum.HumanoidStateType.Freefall or newState == Enum.HumanoidStateType.FallingDown) and States.Farming then
                humanoid:ChangeState(Enum.HumanoidStateType.RunningNoPhysics)
            end
        end)

        if handleDroppedLoot(root, humanoid) then phase4Timeout = 0; continue end

        local chest = getLocalEventChest(root)
        local posterActive = hasBountyPoster(char)
        local marker = workspace:FindFirstChild(MARKER_NAME)
        
        if wasPosterActive and not posterActive then
            bountiesCompleted = bountiesCompleted + 1
            StatsVal.Text = "Completed: " .. tostring(bountiesCompleted)
            phase4Timeout = 0
            Log("Target eliminated successfully.")
            TweenService:Create(TargetCard, TweenInfo.new(0.3), {BackgroundColor3 = THEME.AccentDim}):Play()
            task.delay(0.4, function() TweenService:Create(TargetCard, TweenInfo.new(0.5), {BackgroundColor3 = THEME.CardBg}):Play() end)
            task.wait(1)
            toggleBountyTarget()
        end
        wasPosterActive = posterActive

        if chest then
            Log("Intercepting Event Chest...")
            task.wait(1)
            local prompt = chest:FindFirstChildWhichIsA("ProximityPrompt", true)
            if prompt then
                local origin = prompt.Parent:IsA("Attachment") and prompt.Parent.WorldPosition or prompt.Parent.Position
                if (root.Position - origin).Magnitude > prompt.MaxActivationDistance then
                    root.Anchored = false
                    root.CFrame = CFrame.new(origin + Vector3.new(0, 1.5, 0))
                    task.wait(0.25)
                end
                while prompt and prompt.Enabled and chest.Parent do
                    if fireproximityprompt then fireproximityprompt(prompt) end; task.wait(0.05)
                end
            end
            task.wait(1)
            if chest.Parent then chest:Destroy() end
            phase4Timeout = 0; continue 
        end

        if not posterActive then
            phase4Timeout = 0; root.Anchored = false 
            if (root.Position - LAVA_COORDS.Position).Magnitude > 15 then root.CFrame = LAVA_COORDS end
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.W, false, game); task.wait(0.1)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.W, false, game)
            pcall(function() ReplicatedStorage.Remotes:WaitForChild("TakeBounty"):FireServer("PVE", BOUNTY_NAME) end)
            Log("Awaiting assignment: " .. BOUNTY_NAME); task.wait(1.5) 

        elseif posterActive and marker then
            phase4Timeout = 0; Log("Tethering target to core...")
            root.Anchored = true; root.CFrame = LAVA_COORDS
            humanoid:ChangeState(Enum.HumanoidStateType.RunningNoPhysics)
            local tInfo = TweenInfo.new(TWEEN_DURATION, Enum.EasingStyle.Sine, Enum.EasingDirection.Out)
            local proxy
            if marker:IsA("BasePart") then
                TweenService:Create(marker, tInfo, {CFrame = root.CFrame}):Play()
            elseif marker:IsA("Model") then
                proxy = Instance.new("CFrameValue"); proxy.Value = marker:GetPivot()
                proxy.Changed:Connect(function(c) marker:PivotTo(c) end)
                TweenService:Create(proxy, tInfo, {Value = root.CFrame}):Play()
                task.delay(TWEEN_DURATION, function() if proxy then proxy:Destroy() end end)
            end
            while marker and marker.Parent == workspace and States.Farming do task.wait(0.1) end
            
        elseif posterActive and not marker then
            Log(string.format("Awaiting kill... [%.1fs / 10s]", phase4Timeout))
            root.Anchored = true; humanoid:ChangeState(Enum.HumanoidStateType.RunningNoPhysics)
            phase4Timeout = phase4Timeout + 0.1 
            if phase4Timeout >= TIMEOUT_MAX then
                Log("FAILSAFE: Target timed out. Purging.")
                TweenService:Create(MainCanvas, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(30, 10, 15)}):Play()
                pcall(function() ReplicatedStorage.Remotes:FindFirstChild("TakeBounty"):FireServer("ClearPVE") end)
                phase4Timeout = 0
                task.delay(0.5, function() TweenService:Create(MainCanvas, TweenInfo.new(0.5), {BackgroundColor3 = THEME.Background}):Play() end)
                toggleBountyTarget(); task.wait(1)
            end
        end
    end
end)
