        txt.TextXAlignment = Enum.TextXAlignment.Left
        
        local Del = Instance.new("TextButton", Itm)
        Del.Size = UDim2.new(0, 20, 0, 20)
        Del.Position = UDim2.new(1, -25, 0.5, -10)
        Del.BackgroundTransparency = 1
        Del.Text = "X"
        Del.TextColor3 = THEME.Warning
        Del.Font = Enum.Font.GothamBold
        Del.MouseButton1Click:Connect(function() TargetItems[formattedName] = nil; RefreshItemList() end)
        
        yOff = yOff + 31
    end
    ItemList.CanvasSize = UDim2.new(0, 0, 0, yOff)
end

