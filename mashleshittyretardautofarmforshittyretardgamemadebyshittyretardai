task.spawn(function()
    while task.wait(0.2) do
        if States.AutoRedeem and player.Character then
            local char = player.Character
            local hum = char:FindFirstChildOfClass("Humanoid")
            local backpack = player:FindFirstChild("Backpack")
            local inv = player:FindFirstChild("Data") and player.Data:FindFirstChild("Inventory")

            if hum then
                for fmtName, _ in pairs(TargetItems) do
                    local found = false

                    for _, item in ipairs(char:GetChildren()) do
                        if item:IsA("Tool") and formatString(item.Name) == fmtName then
                            item:Activate()
                            VirtualUser:ClickButton1(Vector2.new(0,0))
                            found = true; break 
                        end
                    end

                    if not found and backpack then
                        for _, item in ipairs(backpack:GetChildren()) do
                            if item:IsA("Tool") and formatString(item.Name) == fmtName then
                                hum:EquipTool(item)
                                task.wait(0.2); item:Activate(); VirtualUser:ClickButton1(Vector2.new(0,0))
                                found = true; break 
                            end
                        end
                    end

                    if not found and inv then
                        for _, itm in ipairs(inv:GetChildren()) do
                            if formatString(itm.Name) == fmtName then
                                local qty = itm:FindFirstChild("Quantity")
                                if qty and qty.Value > 0 then
                                    pcall(function() ReplicatedStorage.Remotes.ItemStorage:FireServer("Withdraw", itm.Name, 1) end)
                                    task.wait(0.2)
                                end
                                break
                            end
                        end
                    end
                end
            end
        end
    end
end)

