-- ==========================================
-- CONFIGURATION & SAVING SYSTEM
-- ==========================================
local ConfigFile = "cyanideAutoWipe_Config.json"
local Config = {
    Enabled = false,
    TargetSlot = 0, 
    AutoCreate = true,
    MainPlaceId = game.PlaceId 
}

local function SaveConfig()
    if writefile then
        writefile(ConfigFile, HttpService:JSONEncode(Config))
    end
end

if isfile and isfile(ConfigFile) then
    local success, result = pcall(function()
        return HttpService:JSONDecode(readfile(ConfigFile))
    end)
    if success and type(result) == "table" then
        local savedPlaceId = result.MainPlaceId
        Config = result
        if savedPlaceId then
            Config.MainPlaceId = savedPlaceId
        end
    end
else
    SaveConfig()
end

-- ==========================================
-- CORE FUNCTIONS
-- ==========================================
local NoclipConnection = nil

local function enableNoclip()
    if NoclipConnection then NoclipConnection:Disconnect() end
    NoclipConnection = RunService.Stepped:Connect(function()
        local char = LocalPlayer.Character
        if char then
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") and part.CanCollide then
                    part.CanCollide = false
                end
            end
        end
    end)
    print("[cyanide] Noclip Enabled for Teleport.")
end

local function disableNoclip()
    if NoclipConnection then
        NoclipConnection:Disconnect()
        NoclipConnection = nil
        print("[cyanide] Noclip Disabled.")
    end
end

local function fixCamera()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local humanoid = char:WaitForChild("Humanoid", 5)
    local rootPart = char:WaitForChild("HumanoidRootPart", 5)
    local camera = workspace.CurrentCamera
    
    if humanoid then
        camera.CameraType = Enum.CameraType.Custom
        camera.CameraSubject = humanoid
    end
    if rootPart then
        rootPart.Anchored = false
    end
    print("[cyanide] Camera and character movement restored.")
end

local function getSlotButton(slotNum)
    local PlayerGui = LocalPlayer:WaitForChild("PlayerGui", 10)
    if not PlayerGui then return nil end

    for _, gui in pairs(PlayerGui:GetChildren()) do
        if gui:IsA("ScreenGui") then
            local slotsFrame = gui:FindFirstChild("SlotsFrame")
            if slotsFrame then
                local totalSlots = slotsFrame:FindFirstChild("TotalSlots")
                if totalSlots then
                    local slotFrame = totalSlots:FindFirstChild(tostring(slotNum))
                    if slotFrame then
                        return slotFrame:FindFirstChild("SlotButton")
                    end
                end
            end
        end
    end
    return nil
end

local function forceClickButton(button)
    local success = false
    -- Try firesignal first (Works on most modern executors)
    if firesignal then
        pcall(function() firesignal(button.MouseButton1Down) end)
        pcall(function() firesignal(button.MouseButton1Click) end)
        pcall(function() firesignal(button.Activated) end)
        success = true
    end
    -- Try getconnections as a fallback/secondary measure
    if getconnections then
        for _, conn in pairs(getconnections(button.MouseButton1Click)) do
            pcall(function() conn:Fire() end)
            pcall(function() conn.Function() end)
            success = true
        end
    end
    return success
end

local function createCharacter()
    local remotes = ReplicatedStorage:WaitForChild("Remotes", 5)
    if not remotes then return end
    
    local genders = {"Male", "Female"}
    local weapons = {"Wand", "Fists", "Sword", "Shield", "Gun"}
    local traits = {"Healthy", "Energetic", "Guarded", "Agile"}
    
    local chosenGender = genders[math.random(1, #genders)]
    local chosenWeapon = weapons[math.random(1, #weapons)]
    local chosenTrait = traits[math.random(1, #traits)]
    
    print(string.format("[Auto-Create] Rolling: %s | %s | %s", chosenGender, chosenWeapon, chosenTrait))
    
    remotes:WaitForChild("ChangeGender"):FireServer(chosenGender)
    task.wait(0.5) 
    remotes:WaitForChild("PickWeapon"):FireServer(chosenWeapon)
    task.wait(0.5)
    remotes:WaitForChild("PickTrait"):FireServer(chosenTrait, "One")
    task.wait(0.5)
    remotes:WaitForChild("FinalizeCharacter"):FireServer()
    print("[Auto-Create] Character finalized successfully!")
    
    task.wait(1)
    remotes:WaitForChild("CloseUI"):FireServer("CreationUI")
end

