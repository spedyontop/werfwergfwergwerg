-- MASTER LOOP
-- ==========================================
task.spawn(function()
    while task.wait(1) do
        if not Config.Enabled then continue end

        -- PHASE 1: DETENTION GAME (BOSS)
        if game.PlaceId ~= Config.MainPlaceId then
            print("[cyanide] In Detention Game. Waiting for Mash Burnedead...")
            
            local live = workspace:WaitForChild("Live", 99999)
            local bossFound = false
            
            while Config.Enabled and not bossFound do
                local boss = live:FindFirstChild("Mash Burnedead")
                if boss and boss:FindFirstChild("BossTag") then
                    bossFound = true
                end
                task.wait(0.5)
            end
            
            if bossFound then
                print("[cyanide] Boss Spawned! Teleporting back to Main Game...")
                task.wait(1)
                TeleportService:Teleport(Config.MainPlaceId, LocalPlayer)
                task.wait(15) 
            end
            continue
        end

        -- PHASE 2: MAIN MENU (SLOT SELECTION)
        local PlayerGui = LocalPlayer:WaitForChild("PlayerGui", 5)
        if PlayerGui and PlayerGui:FindFirstChild("SlotsFrame", true) then
            print("[cyanide] Main Menu detected. Searching for Slot " .. tostring(Config.TargetSlot) .. "...")
            
            local button = nil
            repeat
                if not Config.Enabled then break end
                button = getSlotButton(Config.TargetSlot)
                task.wait(0.5)
            until button
            
            if not Config.Enabled then continue end

            print("[Auto-Slot] SlotButton Found. Attempting force-click...")

            local clicked = false
            while Config.Enabled and not clicked and task.wait(0.5) do
                clicked = forceClickButton(button)
                if clicked then
                    print("[Auto-Slot] Button clicked successfully via executor signals.")
                end
            end
            
            if not Config.Enabled then continue end

            -- Auto Character Creation
            if Config.AutoCreate and clicked then
                print("[Auto-Slot] Waiting for Character Creation UI...")
                local creationUI = nil
                for i = 1, 20 do -- Wait 10 seconds max
                    creationUI = PlayerGui:FindFirstChild("CreationUI")
                    if creationUI then break end
                    task.wait(0.5)
                end
                
                if creationUI then
                    print("[Auto-Slot] Creation UI detected! Auto-creating...")
                    task.wait(1) 
                    createCharacter()
                    task.wait(1)
                    fixCamera()
                else
                    print("[Auto-Slot] No Creation UI detected. Fixing camera...")
                    task.wait(2)
                    fixCamera()
                end
            else
                task.wait(2)
                fixCamera()
            end
            
            local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
            char:WaitForChild("HumanoidRootPart", 15)
            task.wait(3)
            continue 
        end

        -- PHASE 3: IN GAME (QUESTS & WIPE)
        local char = LocalPlayer.Character
        if char and char:FindFirstChild("HumanoidRootPart") and not (PlayerGui and PlayerGui:FindFirstChild("SlotsFrame", true)) then
            print("[cyanide] In-Game detected. Executing Quests & Wipe...")
            
            local remotes = ReplicatedStorage:WaitForChild("Remotes", 5)
            if remotes then
                -- 3A. Standard Quests
                local quests = {
                    "A New Beginning", "Getting Familiar", "Nature's Scent", "The Forge Is Hot!", 
                    "The Overworld", "A New Power", "To Go Beyond", "Weapon Mastery", 
                    "Oversized Fungus", "Rank D", "Gathering the Veins", "Refinement", 
                    "Zooming", "Understanding Magic", "Building Reputation", "King of Arachnids", 
                    "Rank C", "Unfortunate", "Checkpoints", "Magical Power", "An Ancient Problem", 
                    "Rank B", "Retired Mage", "The Messenger", "Magic Mentor", 
                    "The Relighted Souls", "Awakened Slumber", "Maximum Power!", 
                    "Rank A", "Icebound", "Domain of the Monarch", "Living Forge"
                }

                for _, quest in ipairs(quests) do
                    if not Config.Enabled then break end
                    remotes:WaitForChild("CompleteQuest"):FireServer(quest, {Skip = true})
                    task.wait(0.05) 
                end

                if not Config.Enabled then continue end

                -- 3B. Evolution Quests
                remotes:WaitForChild("CompleteQuest"):FireServer("Evolution", {Progress = true})
                task.wait(1)
                remotes:WaitForChild("CompleteQuest"):FireServer("Evolution")
                task.wait(1)

                if not Config.Enabled then continue end

                -- 3C. Teleport and Detention Wipe
                print("[cyanide] Teleporting to Detention Wipe...")
                
                -- ENABLE NOCLIP BEFORE TELEPORTING
                enableNoclip()
                
                char.HumanoidRootPart.CFrame = CFrame.new(-3049, -78, 2659)
                task.wait(0.5)
                
                remotes:WaitForChild("DetentionOption"):FireServer()
                print("[cyanide] Wipe triggered. Waiting for cross-game teleport...")
                
                task.wait(15) 
                disableNoclip()
            end
        end
    end
end)

