-- ==========================================
-- HELPER FUNCTIONS
-- ==========================================

local function IsPlayerNearPosition(targetPos, radius)
    if radius <= 0 then return false end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local targetHrp = p.Character:FindFirstChild("HumanoidRootPart")
            local targetHum = p.Character:FindFirstChild("Humanoid")
            
            if targetHrp and targetHum and targetHum.Health > 0 then
                local dist = (Vector2.new(targetPos.X, targetPos.Z) - Vector2.new(targetHrp.Position.X, targetHrp.Position.Z)).Magnitude
                if dist <= radius then
                    return true
                end
            end
        end
    end
    return false
end

local function TriggerReset(reason)
    if getgenv().IsResetting then return end
    getgenv().IsResetting = true
    UpdateStatus("Resetting (" .. reason .. ")...")
    
    pcall(function()
        ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("ResetCooldown"):FireServer()
    end)
    
    task.wait(5)
    getgenv().IsResetting = false
end

local function GetHRP()
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    return char:FindFirstChild("HumanoidRootPart")
end

local function TeleportTo(cframe)
    local hrp = GetHRP()
    if hrp and not getgenv().IsResetting then
        hrp.CFrame = cframe
    end
end

local function ExploitPrompt(prompt)
    if not prompt or getgenv().IsResetting then return end 
    pcall(function()
        prompt.RequiresLineOfSight = false
        prompt.MaxActivationDistance = 9e9
        prompt.HoldDuration = 0 
        
        if fireproximityprompt then
            fireproximityprompt(prompt)
        else
            prompt:InputHoldBegin()
            task.wait(0.05)
            prompt:InputHoldEnd()
        end
    end)
end

local function GetItemPosition(item)
    if item:IsA("BasePart") then return item.Position end
    if item:IsA("Model") and item.PrimaryPart then return item.PrimaryPart.Position end
    if item:IsA("Model") then return item:GetPivot().Position end
    local firstPart = item:FindFirstChildWhichIsA("BasePart", true)
    if firstPart then return firstPart.Position end
    return nil
end

