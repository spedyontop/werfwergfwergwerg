-- ==========================================
-- HELPER FUNCTIONS
-- ==========================================
local function GetNextBounty()
    if getgenv().FarmMonster and getgenv().FarmWinter then
        lastBountyDone = (lastBountyDone == "Winter Outbreak") and "Monster Sighting" or "Winter Outbreak"
        return lastBountyDone
    elseif getgenv().FarmMonster then
        return "Monster Sighting"
    elseif getgenv().FarmWinter then
        return "Winter Outbreak"
    end
    return nil 
end

local function GetHRP()
    -- Optimized: No longer yields. Returns nil instantly if dead.
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function IsPlayerNearPosition(targetPos, radius)
    if radius <= 0 then return false end
    local radSq = radius * radius -- Optimized: Avoids math.sqrt in the loop
    
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local targetHrp = p.Character:FindFirstChild("HumanoidRootPart")
            local targetHum = p.Character:FindFirstChild("Humanoid")
            
            if targetHrp and targetHum and targetHum.Health > 0 then
                local dx = targetPos.X - targetHrp.Position.X
                local dz = targetPos.Z - targetHrp.Position.Z
                if (dx * dx + dz * dz) <= radSq then
                    return true
                end
            end
        end
    end
    return false
end

-- ==========================================
-- EMERGENCY EVASION & ABORT SYSTEM
-- ==========================================
local function EmergencySkyTP()
    local hrp = GetHRP()
    if hrp then
        hrp.Anchored = true
        hrp.CFrame = hrp.CFrame + Vector3.new(0, 1000, 0)
        task.wait(0.05)
        hrp.Anchored = false
    end
end

local function AbortBounty(reason)
    if getgenv().IsAborting then return end
    getgenv().IsAborting = true
    UpdateStatus("Aborting (" .. reason .. ")...")
    
    local isPlayerEvasion = string.find(reason:lower(), "player")
    
    if isPlayerEvasion then
        EmergencySkyTP()
        pcall(function() TakeBountyRemote:FireServer("ClearPVE") end)
        UpdateStatus("Evasively cleared quest. Waiting 2s...")
        task.wait(2)
    else
        pcall(function() TakeBountyRemote:FireServer("ClearPVE") end)
        EmergencySkyTP()
        UpdateStatus("Cleared quest. Waiting 2s...")
        task.wait(2)
    end
    
    getgenv().IsAborting = false
end

-- ==========================================
-- STRICT SAFE TELEPORT & TWEEN
-- ==========================================
local function SafeTeleport(cframe)
    if getgenv().IsAborting then return false end
    
    if getgenv().AntiPlayerRadius > 0 and IsPlayerNearPosition(cframe.Position, getgenv().AntiPlayerRadius) then
        task.spawn(function() AbortBounty("Player at teleport destination") end)
        return false
    end
    
    local hrp = GetHRP()
    if hrp then
        hrp.CFrame = cframe
        return true
    end
    return false
end

local function PlayTweenSafe(tween, duration)
    tween:Play()
    local elapsed = 0
    while elapsed < duration do
        if getgenv().IsAborting then 
            tween:Cancel() 
            return false 
        end
        task.wait(0.1)
        elapsed = elapsed + 0.1
    end
    return true
end

local function SafeTween(hrp, cframe, duration)
    if not SafeTeleport(cframe) then return false end
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(hrp, tweenInfo, {CFrame = cframe})
    return PlayTweenSafe(tween, duration)
end

