-- ==========================================
-- MAIN AUTOFARM LOGIC
-- ==========================================
local Remotes = ReplicatedStorage:WaitForChild("Remotes", 10)
local TakeBounty = Remotes and Remotes:WaitForChild("TakeBounty", 5)
local LiveFolder = Workspace:WaitForChild("Live", 10)
local Interactables = Workspace:WaitForChild("Interactables", 10)

local function DoBountyCycle()
    if not TakeBounty or getgenv().IsResetting then return end

    -- 1. Accept Bounty
    UpdateStatus("Accepting Bounty...")
    pcall(function() TakeBounty:FireServer("PVE", getgenv().SelectedBounty) end)
    task.wait(1)
    if getgenv().IsResetting then return end

    -- 2. Go to Marker
    UpdateStatus("Going to Marker...")
    local marker = Workspace:WaitForChild("MissionMarker", 10)
    if marker then
        local markerCFrame = marker:IsA("Model") and marker:GetPivot() or marker.CFrame
        if IsPlayerNearPosition(markerCFrame.Position, getgenv().AntiPlayerRadius) then
            TriggerReset("Player camped at Marker")
            return
        end
        TeleportTo(markerCFrame)
        task.wait(0.5)
    end
    if getgenv().IsResetting then return end

    -- 3. Wait for Boss
    UpdateStatus("Waiting for Boss...")
    local targetBoss = nil
    for i = 1, 100 do
        if not getgenv().AutoBounty or getgenv().IsResetting then return end
        for _, model in ipairs(LiveFolder:GetChildren()) do
            if model:FindFirstChild("BossTag") then
                targetBoss = model
                break
            end
        end
        if targetBoss then break end
        task.wait(0.1)
    end
    if getgenv().IsResetting then return end

    -- 4. Simple Combat (WITH 60s TIMEOUT)
    if targetBoss then
        UpdateStatus("Fighting " .. targetBoss.Name .. "...")
        local combatStart = os.clock()
        
        while targetBoss.Parent == LiveFolder and targetBoss:FindFirstChild("BossTag") and getgenv().AutoBounty and not getgenv().IsResetting do
            -- 60 Second Kill Timeout Check
            if os.clock() - combatStart >= 60 then
                TriggerReset("Boss kill timeout (60s)")
                return
            end

            local bossPos = targetBoss:GetPivot().Position
            if IsPlayerNearPosition(bossPos, getgenv().AntiPlayerRadius) then
                TriggerReset("Player near Boss")
                return
            end
            
            TeleportTo(targetBoss:GetPivot() * CFrame.new(0, 0, 4))
            task.wait(0.1) 
        end
    end
    if getgenv().IsResetting then return end

    -- 5. THE REACTIVE 10-STUD LOOTING
    UpdateStatus("Waiting for Event Chest...")
    local chest = Interactables:WaitForChild("Event Chest", 15)
    
    if chest then
        UpdateStatus("Chest found. Exploiting...")
        local chestPrompt = nil
        
        repeat
            task.wait(0.1)
            chestPrompt = chest:FindFirstChildWhichIsA("ProximityPrompt", true)
        until chestPrompt or not chest.Parent or not getgenv().AutoBounty or getgenv().IsResetting
        
        if getgenv().IsResetting then return end

        local chestEpicenter = GetItemPosition(chest)

        if chestPrompt and chest.Parent and chestEpicenter then
            local promptPart = chestPrompt.Parent
            if IsPlayerNearPosition(chestEpicenter, getgenv().AntiPlayerRadius) then
                TriggerReset("Player camping Chest")
                return
            end
            
            local lootSpawned = false
            local timeout = os.clock() + 10 

            while not lootSpawned and os.clock() < timeout and getgenv().AutoBounty and not getgenv().IsResetting do
                TeleportTo(promptPart:IsA("BasePart") and promptPart.CFrame or CFrame.new(chestEpicenter))
                ExploitPrompt(chestPrompt)
                
                for _, item in ipairs(Interactables:GetChildren()) do
                    if item ~= chest then
                        local itemPos = GetItemPosition(item)
                        if itemPos and (itemPos - chestEpicenter).Magnitude <= 10 then
                            lootSpawned = true
                            break
                        end
                    end
                end
                task.wait(0.1)
            end
        end

        if getgenv().IsResetting then return end
        UpdateStatus("Sweeping drops...")
        task.wait(0.5) 

        -- RELENTLESS SWEEP: Spam all items in radius until they are physically gone
        if chestEpicenter then
            local sweepTimeout = os.clock() + 5 
            
            while os.clock() < sweepTimeout and getgenv().AutoBounty and not getgenv().IsResetting do
                local itemsLeft = false
                
                for _, item in ipairs(Interactables:GetChildren()) do
                    if item.Name ~= "Event Chest" then
                        local itemPos = GetItemPosition(item)
                        if itemPos and (itemPos - chestEpicenter).Magnitude <= 10 then
                            local itemPrompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
                            if itemPrompt then
                                itemsLeft = true
                                TeleportTo(CFrame.new(itemPos)) 
                                task.wait(0.1)
                                ExploitPrompt(itemPrompt)
                            end
                        end
                    end
                end
                
                if not itemsLeft then
                    break -- All items successfully grabbed
                end
                task.wait(0.2)
            end
        end

        UpdateStatus("Loot secured. Restarting...")
    else
        UpdateStatus("No chest spawned. Restarting...")
    end
    
    task.wait(1)
end

