local function ExploitPrompt(prompt)
    if not prompt or getgenv().IsAborting then return end 
    pcall(function()
        prompt.RequiresLineOfSight = false
        prompt.MaxActivationDistance = 9e9
        prompt.HoldDuration = 0 
        
        if fireproximityprompt then
            fireproximityprompt(prompt)
        else
            prompt:InputHoldBegin()
            task.wait(0.05)
            prompt:InputHoldEnd()
        end
    end)
end

local function GetItemPosition(item)
    if item:IsA("BasePart") then return item.Position end
    if item:IsA("Model") and item.PrimaryPart then return item.PrimaryPart.Position end
    if item:IsA("Model") then return item:GetPivot().Position end
    local firstPart = item:FindFirstChildWhichIsA("BasePart", true)
    if firstPart then return firstPart.Position end
    return nil
end

-- ==========================================
-- EVENT-LISTENER LOOTING SYSTEM (FAST SWEEP)
-- ==========================================
local function DoLooting()
    UpdateStatus("Waiting for Event Chest...")
    local chest = Interactables:WaitForChild("Event Chest", 15)
    
    if not chest then
        UpdateStatus("No chest spawned.")
        return
    end

    UpdateStatus("Chest found. Setting up listener...")
    local chestPrompt = nil
    
    repeat
        task.wait(0.1)
        chestPrompt = chest:FindFirstChildWhichIsA("ProximityPrompt", true)
    until chestPrompt or not chest.Parent or not getgenv().AutoBounty or getgenv().IsAborting
    
    if getgenv().IsAborting or not chest.Parent then return end

    local chestEpicenter = GetItemPosition(chest)
    if not chestEpicenter then return end
    
    local promptPart = chestPrompt.Parent
    local desiredLootCFrame = promptPart:IsA("BasePart") and promptPart.CFrame or CFrame.new(chestEpicenter)

    local droppedLoot = {}
    local dropConnection = Interactables.ChildAdded:Connect(function(child)
        if child.Name ~= "Event Chest" then
            table.insert(droppedLoot, child)
        end
    end)

    local chestTimeout = os.clock() + 10 
    local lastLootCount = 0
    local idleTime = 0

    UpdateStatus("Opening Chest...")

    while os.clock() < chestTimeout and getgenv().AutoBounty and not getgenv().IsAborting do
        local hrp = GetHRP()
        if hrp and (hrp.Position - desiredLootCFrame.Position).Magnitude > 3 then
            if not SafeTeleport(desiredLootCFrame) then 
                dropConnection:Disconnect()
                return 
            end
        end
        
        ExploitPrompt(chestPrompt)
        
        if #droppedLoot > 0 then
            if #droppedLoot == lastLootCount then
                idleTime = idleTime + 0.1
                if idleTime >= 1.5 then break end
            else
                lastLootCount = #droppedLoot
                idleTime = 0
            end
        end
        task.wait(0.1)
    end

    dropConnection:Disconnect()
    if getgenv().IsAborting then return end

    if #droppedLoot > 0 then
        UpdateStatus("Sweeping " .. #droppedLoot .. " items rapidly...")
        task.wait(0.1) 

        local sweepTimeout = os.clock() + 4 
        local firedPrompts = {} -- Prevent redundant thread creation
        
        while os.clock() < sweepTimeout and getgenv().AutoBounty and not getgenv().IsAborting do
            local itemsRemaining = false
            
            for _, item in ipairs(droppedLoot) do
                if item.Parent == Interactables then
                    local itemPrompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
                    
                    if itemPrompt then
                        itemsRemaining = true
                        local itemPos = GetItemPosition(item)
                        
                        if itemPos then
                            local hrp = GetHRP()
                            if hrp and (hrp.Position - itemPos).Magnitude > 12 then
                                if not SafeTeleport(CFrame.new(itemPos)) then return end
                                task.wait(0.05) 
                            end
                            
                            if not firedPrompts[itemPrompt] then
                                firedPrompts[itemPrompt] = true
                                task.spawn(function()
                                    ExploitPrompt(itemPrompt)
                                    task.wait(0.5)
                                    firedPrompts[itemPrompt] = nil -- Free it up if it failed
                                end)
                            end
                        end
                    end
                end
            end
            
            if not itemsRemaining then break end
            task.wait(0.1) 
        end
        UpdateStatus("Loot secured.")
    else
        UpdateStatus("Chest opened, but no loot dropped.")
    end
end

-- ==========================================
-- MAIN AUTOFARM LOGIC
-- ==========================================
local function DoBountyCycle()
    if getgenv().IsAborting then return end

    local targetBounty = GetNextBounty()
    if not targetBounty then
        UpdateStatus("Waiting: No bounty selected in UI")
        task.wait(1)
        return
    end

    UpdateStatus("Accepting: " .. targetBounty .. "...")
    pcall(function() TakeBountyRemote:FireServer("PVE", targetBounty) end)
    
    UpdateStatus("Bounty accepted. Letting server load...")
    task.wait(3)
    
    if getgenv().IsAborting then return end

    UpdateStatus("Going to Marker...")
    local marker = Workspace:WaitForChild("MissionMarker", 3)
    if marker then
        local markerCFrame = marker:IsA("Model") and marker:GetPivot() or marker.CFrame
        if SafeTeleport(markerCFrame) then
            task.wait(0.5)
            marker:Destroy() 
        end
    end
    if getgenv().IsAborting then return end

    UpdateStatus("Waiting for Boss (7s)...")
    local targetBoss = nil
    for i = 1, 70 do
        if not getgenv().AutoBounty or getgenv().IsAborting then return end
        for _, model in ipairs(LiveFolder:GetChildren()) do
            if model:FindFirstChild("BossTag") then
                targetBoss = model
                break
            end
        end
        if targetBoss then break end
        task.wait(0.1)
    end
    if getgenv().IsAborting then return end

    if not targetBoss then
        local backupChest = Interactables:FindFirstChild("Event Chest")
        if backupChest then
            UpdateStatus("No boss, but chest found! Skipping to loot...")
        else
            AbortBounty("Boss timeout & no chest found")
            return
        end
    end

    -- ==========================================
    -- EXACT BOSS COMBAT LOGIC
    -- ==========================================
    if targetBoss then
        local bossName = targetBoss.Name:lower() 
        
        local shouldSkip = false
        for _, ignoredBoss in ipairs(getgenv().IgnoredBosses) do
            if string.find(bossName, ignoredBoss:lower()) then
                shouldSkip = true
                break
            end
        end
        
        if shouldSkip then
            AbortBounty("Skipped ignored boss: " .. targetBoss.Name)
            return
        end
        
        UpdateStatus("Fighting " .. targetBoss.Name .. "...")
        local combatStart = os.clock()
        
        while targetBoss.Parent == LiveFolder and targetBoss:FindFirstChild("BossTag") and getgenv().AutoBounty and not getgenv().IsAborting do
            if os.clock() - combatStart >= 60 then
                AbortBounty("Boss kill timeout (60s)")
                return
            end

            local bossHrp = targetBoss:FindFirstChild("HumanoidRootPart")
            if not bossHrp then
                task.wait(0.1)
                continue
            end

            if string.find(bossName, "minotaur") then
                local hrp = GetHRP()
                if hrp then
                    local diagonalCFrame = bossHrp.CFrame * CFrame.new(0, 200, 356.4)
                    if not SafeTween(hrp, diagonalCFrame, 0.5) then return end
                    
                    if targetBoss.Parent == LiveFolder and getgenv().AutoBounty then
                        local newBackCFrame = bossHrp.CFrame * CFrame.new(0, 0, 10)
                        if not SafeTween(hrp, newBackCFrame, 0.5) then return end
                        task.wait(3)
                    end
                end
            else
                local desiredCFrame = bossHrp.CFrame * CFrame.new(0, 0, 4)
                local hrp = GetHRP()
                
                if hrp then
                    -- Simplified distance math
                    local dx = hrp.Position.X - desiredCFrame.Position.X
                    local dy = hrp.Position.Y - desiredCFrame.Position.Y
                    local dz = hrp.Position.Z - desiredCFrame.Position.Z
                    local distSq = (dx*dx + dy*dy + dz*dz)
                    
                    if distSq > 225 then -- 15 squared
                        if not SafeTeleport(desiredCFrame) then return end
                    else
                        local smoothTween = TweenService:Create(hrp, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {CFrame = desiredCFrame})
                        smoothTween:Play()
                    end
                end
                task.wait(0.1) 
            end
        end
    end
    if getgenv().IsAborting then return end

    DoLooting()
    UpdateStatus("Restarting Cycle...")
    task.wait(1)
end

