local function GetBackpackString()
    local inventory = {}
    local function scan(parent)
        if not parent then return end
        for _, item in ipairs(parent:GetChildren()) do
            if item:IsA("Tool") then
                local qtyObj = item:FindFirstChild("Quantity")
                local count = 1
                
                if qtyObj and (qtyObj:IsA("IntValue") or qtyObj:IsA("NumberValue")) then
                    count = qtyObj.Value
                end
                
                inventory[item.Name] = (inventory[item.Name] or 0) + count
            end
        end
    end
    
    scan(LocalPlayer:FindFirstChild("Backpack"))
    scan(LocalPlayer.Character)
    
    local str = ""
    for name, count in pairs(inventory) do
        str = str .. name .. " [x" .. count .. "]\n"
    end
    
    if str == "" then 
        return "Empty" 
    else
        return string.sub(str, 1, -2) 
    end
end

local function SendWebhook()
    if not webhookEnabled or webhookUrl == "" then return end
    
    if lastSessionStats.TimeTaken == 0 and lastSessionStats.ChestsLooted == 0 then return end
    
    local timeStr = tostring(lastSessionStats.TimeTaken) .. " seconds"
    if lastSessionStats.TimeTaken > 60 then
        timeStr = tostring(math.floor(lastSessionStats.TimeTaken / 60)) .. "m " .. tostring(lastSessionStats.TimeTaken % 60) .. "s"
    end
    
    local placeName = "bridger: WESTERN"
    pcall(function()
        placeName = game:GetService("MarketplaceService"):GetProductInfo(game.PlaceId).Name
    end)
    
    -- Extract Moola value safely
    local moolaAmount = "Unknown"
    pcall(function()
        local moolaUI = LocalPlayer.PlayerGui:FindFirstChild("MoolaCount")
        if moolaUI and moolaUI:FindFirstChild("TextLabel") then
            local rawText = moolaUI.TextLabel.Text
            -- Grabs only the numbers (and commas if they exist) from "Moola: 14332"
            local match = string.match(rawText, "[%d,]+") 
            if match then
                moolaAmount = match
            else
                moolaAmount = rawText
            end
        end
    end)
    
    local data = {
        ["embeds"] = {{
            ["title"] = "Cyanide's Auto Chest",
            ["description"] = "Username: ||" .. LocalPlayer.Name .. "||\nMoola (Cash): ``" .. moolaAmount .. "``\nTime Taken: ``" .. timeStr .. "``\nTotal Chests Looted: ``Chests [x" .. tostring(lastSessionStats.ChestsLooted) .. "]``",
            ["color"] = 11861934,
            ["fields"] = {
                {
                    ["name"] = "Current Backpack",
                    ["value"] = GetBackpackString()
                }
            },
            ["author"] = {
                ["name"] = "Successfully rejoined " .. placeName .. ""
            },
            ["footer"] = {
                ["text"] = "Made by cyanideunderground & gem",
                ["icon_url"] = "https://cdn.discordapp.com/attachments/1486729906388734032/1487395856083845260/DI8Les9.png?ex=69c8fcd6&is=69c7ab56&hm=c503257738c1468178cfc70e943e60d501d36fe94821412ad0c1920a6013202b&"
            }
        }}
    }
    
    local requestFunc = request or http_request or (syn and syn.request)
    if requestFunc then
        pcall(function()
            requestFunc({
                Url = webhookUrl,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode(data)
            })
        end)
    end
end

