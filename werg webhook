-- Executor HTTP Request Support
local httprequest = (syn and syn.request) or (http and http.request) or http_request or (fluxus and fluxus.request) or request
if not httprequest then
    LocalPlayer:Kick("Your executor does not support HTTP requests.")
    return
end

-- ==========================================
-- CONFIGURATION & SAVING SYSTEM
-- ==========================================
local Config = {
    WebhookURL = "",
    SendOnTimer = false,
    TimerInterval = 60,
    SendOnUpdate = false
}

local configFileName = "MashleWebhookConfig.json"

local function SaveConfig()
    if writefile then
        pcall(function()
            writefile(configFileName, HttpService:JSONEncode(Config))
        end)
    end
end

local function LoadConfig()
    if isfile and readfile and isfile(configFileName) then
        pcall(function()
            local decoded = HttpService:JSONDecode(readfile(configFileName))
            if type(decoded) == "table" then
                for k, v in pairs(decoded) do
                    Config[k] = v
                end
            end
        end)
    end
end

LoadConfig()

local lastUpdateSend = 0
local updateConnections = {}

local function GetVal(path)
    if path and typeof(path) == "Instance" and path:IsA("ValueBase") then
        return tostring(path.Value)
    elseif path then
        return tostring(path)
    end
    return "N/A"
end

-- ==========================================
-- WEBHOOK LOGIC
-- ==========================================
local function FireWebhook()
    if Config.WebhookURL == "" then return end

    local dataFolder = LocalPlayer:FindFirstChild("Data")
    local slotChosen = LocalPlayer:FindFirstChild("SlotChosen")
    
    local coins = dataFolder and dataFolder:FindFirstChild("Coins")
    local goldCoins = dataFolder and dataFolder:FindFirstChild("GoldCoins")
    local magicMastery = dataFolder and dataFolder:FindFirstChild("MagicMastery")
    local magicMark = dataFolder and dataFolder:FindFirstChild("MagicMarkProgression")

    local msg = {
        ["embeds"] = {
            {
                ["title"] = "Mashle Academy Tracker",
                ["color"] = 2303786, 
                ["fields"] = {
                    {
                        ["name"] = "User",
                        ["value"] = "||" .. LocalPlayer.Name .. "|| (Slot " .. GetVal(slotChosen) .. ")",
                        ["inline"] = false
                    },
                    {
                        ["name"] = "Wealth",
                        ["value"] = "Coins: " .. GetVal(coins) .. "\nGold: " .. GetVal(goldCoins),
                        ["inline"] = true
                    },
                    {
                        ["name"] = "Magic",
                        ["value"] = "Mastery: " .. GetVal(magicMastery) .. "\nMark: " .. GetVal(magicMark),
                        ["inline"] = true
                    }
                },
                ["footer"] = {
                    ["text"] = "Automated Ping • " .. os.date("%X")
                }
            }
        }
    }

    pcall(function()
        httprequest({
            Url = Config.WebhookURL,
            Method = "POST",
            Headers = { ["Content-Type"] = "application/json" },
            Body = HttpService:JSONEncode(msg)
        })
    end)
end

-- ==========================================
-- LISTENERS & TIMERS
-- ==========================================
local function ClearConnections()
    for _, conn in ipairs(updateConnections) do
        conn:Disconnect()
    end
    updateConnections = {}
end

local function SetupUpdateListeners()
    ClearConnections()
    if not Config.SendOnUpdate then return end

    local dataFolder = LocalPlayer:WaitForChild("Data", 5)
    if not dataFolder then return end

    local statsToTrack = {"Coins", "GoldCoins", "MagicMastery", "MagicMarkProgression"}

    for _, statName in ipairs(statsToTrack) do
        local statObj = dataFolder:FindFirstChild(statName)
        if statObj and statObj:IsA("ValueBase") then
            local conn = statObj.Changed:Connect(function()
                if os.clock() - lastUpdateSend >= 3 then
                    lastUpdateSend = os.clock()
                    FireWebhook()
                end
            end)
            table.insert(updateConnections, conn)
        end
    end
end

SetupUpdateListeners()

task.spawn(function()
    while task.wait(1) do
        if Config.SendOnTimer and Config.TimerInterval > 0 then
            task.wait(Config.TimerInterval - 1)
            if Config.SendOnTimer then
                FireWebhook()
            end
        end
    end
end)

