local HorseConfig = {
    SpeedMultiplier = 2.5,
    JumpMultiplier = 2,
    InfiniteStamina = true
}

local function updateHorses()
    local staminaValue = HorseConfig.InfiniteStamina and 99999 or 1 

    for _, instance in pairs(workspace:GetDescendants()) do
        if instance:IsA("Model") and instance:GetAttribute("Stat_Speed") ~= nil then
            instance:SetAttribute("Stat_Speed", HorseConfig.SpeedMultiplier)
            instance:SetAttribute("Stat_Jump", HorseConfig.JumpMultiplier)
            instance:SetAttribute("Stat_Stamina", staminaValue)
        end
    end
end

workspace.DescendantAdded:Connect(function(instance)
    task.wait(0.5)
    if instance:IsA("Model") and instance:GetAttribute("Stat_Speed") ~= nil then
        local staminaValue = HorseConfig.InfiniteStamina and 99999 or 1
        instance:SetAttribute("Stat_Speed", HorseConfig.SpeedMultiplier)
        instance:SetAttribute("Stat_Jump", HorseConfig.JumpMultiplier)
        instance:SetAttribute("Stat_Stamina", staminaValue)
    end
end)

task.spawn(function()
    local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")
    
    while task.wait(0.5) do
        local HorseControlGui = PlayerGui:FindFirstChild("HorseControlGui")
        if HorseControlGui then
            local StaminaBar = HorseControlGui:FindFirstChild("StaminaBar")
            local StaminaFill = StaminaBar and StaminaBar:FindFirstChild("StaminaFill")
            
            if StaminaFill and not StaminaFill:GetAttribute("SizeLockHooked") then
                StaminaFill:SetAttribute("SizeLockHooked", true)
                
                StaminaFill:GetPropertyChangedSignal("Size"):Connect(function()
                    if HorseConfig.InfiniteStamina then
                        local lockedSize = UDim2.new(1, 0, 1, 0)
                        if StaminaFill.Size ~= lockedSize then
                            StaminaFill.Size = lockedSize
                        end
                    end
                end)
                
                if HorseConfig.InfiniteStamina then
                    StaminaFill.Size = UDim2.new(1, 0, 1, 0)
                end
            end
        end
    end
end)

TabScripts:CreateButton({
    Name = "Execute Infinite Stamina",
    Callback = function()
        local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local LocalPlayer = Players.LocalPlayer
local StaminaRemote = ReplicatedStorage:WaitForChild("Remotes"):WaitForChild("StaminaUpdate")

local SPRINT_SPEED = 25
local DEFAULT_SPEED = 16

local entityFolder = workspace:FindFirstChild("Entities")
local myEntity = nil
local targetAnim = nil

for _, connection in pairs(getconnections(StaminaRemote.OnClientEvent)) do
    pcall(function()
        if connection.Disable then
            connection:Disable()
        elseif pcall(function() return connection.Enabled end) then
            connection.Enabled = false
        end
    end)
end

task.spawn(function()
    while true do
        firesignal(StaminaRemote.OnClientEvent, 100, 100)
        task.wait(0.1)
    end
end)

RunService.Heartbeat:Connect(function()
    local char = LocalPlayer.Character
    local hum = char and char:FindFirstChild("Humanoid")
    if not hum or hum.Health <= 0 then return end
    
    if not myEntity or myEntity.Parent ~= entityFolder then
        myEntity = entityFolder and entityFolder:FindFirstChild(LocalPlayer.Name)
        targetAnim = myEntity and myEntity:FindFirstChild("RunningAnim")
    end

    local animator = hum:FindFirstChild("Animator")
    if animator and targetAnim then
        local isRunningAnimActive = false
        
        for _, track in ipairs(animator:GetPlayingAnimationTracks()) do
            if track.Animation == targetAnim then
                isRunningAnimActive = true
                break
            end
        end

        if isRunningAnimActive then
            if hum.WalkSpeed ~= SPRINT_SPEED then
                hum.WalkSpeed = SPRINT_SPEED
            end
        else
            if hum.WalkSpeed == SPRINT_SPEED then
                hum.WalkSpeed = DEFAULT_SPEED
            end
        end
    end
end)
        print("[cyanide] Stamina updated to infinite.")
    end,
})

-- Anti Recoil
TabScripts:CreateButton({
    Name = "Anti Recoil",
    Callback = function()
        local ReplicatedStorage = game:GetService("ReplicatedStorage")

        local VFXModule = require(ReplicatedStorage:WaitForChild("Modules"):WaitForChild("VFXModule"))

        if VFXModule and type(VFXModule.RequestRecoilShake) == "function" then
            VFXModule.RequestRecoilShake = function() 
                return nil 
            end
        end

        local oldRequire
        oldRequire = hookfunction(require, function(module)
            local result = oldRequire(module)
            
            if type(result) == "table" then
                -- Only modifying the visual/physical kick intensity
                if result.ShakeIntensity then result.ShakeIntensity = 0 end
                if result.ShakeDuration then result.ShakeDuration = 0 end
                if result.AimingShakeMultiplier then result.AimingShakeMultiplier = 0 end
            end
            
            return result
        end)

        local function ClearCurrentRecoil()
            for _, v in pairs(game:GetDescendants()) do
                if v:IsA("ModuleScript") and (v.Name == "ServerConfig" or v.Name == "ClientConfig") then
                    pcall(function()
                        local config = require(v)
                        if type(config) == "table" then
                            config.ShakeIntensity = 0
                            config.ShakeDuration = 0
                            config.AimingShakeMultiplier = 0
                        end
                    end)
                end
            end
        end

        task.spawn(ClearCurrentRecoil)
        print("[cyanide] Recoil disabled.")
    end,
})

