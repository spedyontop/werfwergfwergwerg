local PilotModule = require(game:GetService("ReplicatedStorage"):WaitForChild("Modules"):WaitForChild("StandPilotController"))

local PilotStatsEnabled = false
local InfiniteRangeEnabled = false
local ActiveStatsTable = nil
local OriginalStats = {}

local MyPilotStats = {
    SprintSpeed = 1200,
    Speed = 600,
}

local function ApplyPilotStats()
    if not ActiveStatsTable then return end
    
    if InfiniteRangeEnabled then
        ActiveStatsTable.MaxRange = 9e18
    else
        if OriginalStats.MaxRange then
            ActiveStatsTable.MaxRange = OriginalStats.MaxRange
        end
    end

    if PilotStatsEnabled then
        ActiveStatsTable.SprintSpeed = MyPilotStats.SprintSpeed
        ActiveStatsTable.Speed = MyPilotStats.Speed
        ActiveStatsTable.ReturnSpeed = MyPilotStats.ReturnSpeed or 65
    else
        if OriginalStats.Speed then
            ActiveStatsTable.SprintSpeed = OriginalStats.SprintSpeed
            ActiveStatsTable.Speed = OriginalStats.Speed
            ActiveStatsTable.ReturnSpeed = OriginalStats.ReturnSpeed
        end
    end
end

local oldStart = PilotModule.StartPiloting

PilotModule.StartPiloting = function(model, stats, controls)
    if type(stats) == "table" then
        ActiveStatsTable = stats
        OriginalStats.MaxRange = stats.MaxRange
        OriginalStats.SprintSpeed = stats.SprintSpeed
        OriginalStats.Speed = stats.Speed
        OriginalStats.ReturnSpeed = stats.ReturnSpeed

        ApplyPilotStats()
    end
    return oldStart(model, stats, controls)
end

