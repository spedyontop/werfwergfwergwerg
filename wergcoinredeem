MasterToggleBtn.MouseButton1Click:Connect(function()
    AutoRedeemEnabled = not AutoRedeemEnabled
    if AutoRedeemEnabled then
        MasterToggleBtn.Text = "[X] Enable Auto Redeem"
        MasterToggleBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
    else
        MasterToggleBtn.Text = "[ ] Enable Auto Redeem"
        MasterToggleBtn.TextColor3 = Color3.fromRGB(170, 170, 170)
    end
end)

local function RefreshItemList()
    for _, child in ipairs(ItemListFrame:GetChildren()) do
        if child:IsA("TextButton") then
            child:Destroy()
        end
    end

    local yOffset = 0
    for itemName, displayString in pairs(TargetItems) do
        local itemBtn = Instance.new("TextButton")
        itemBtn.Size = UDim2.new(1, -8, 0, 22)
        itemBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
        itemBtn.BorderColor3 = Color3.fromRGB(15, 15, 15)
        itemBtn.BorderSizePixel = 1
        itemBtn.Text = "- " .. displayString .. " [X]"
        itemBtn.TextColor3 = Color3.fromRGB(200, 100, 100)
        itemBtn.Font = Enum.Font.RobotoMono
        itemBtn.TextSize = 13
        itemBtn.TextXAlignment = Enum.TextXAlignment.Left
        itemBtn.Parent = ItemListFrame

        local ItemPadding = Instance.new("UIPadding")
        ItemPadding.PaddingLeft = UDim.new(0, 8)
        ItemPadding.Parent = itemBtn

        itemBtn.MouseButton1Click:Connect(function()
            TargetItems[itemName] = nil
            RefreshItemList()
        end)
        
        yOffset = yOffset + 24
    end
    
    ItemListFrame.CanvasSize = UDim2.new(0, 0, 0, yOffset)
end

AddBtn.MouseButton1Click:Connect(function()
    local rawText = InputBox.Text
    local formattedText = formatString(rawText)
    
    if formattedText ~= "" and not TargetItems[formattedText] then
        TargetItems[formattedText] = rawText 
        InputBox.Text = ""
        RefreshItemList()
    end
end)

-- ==========================================
-- MAIN AUTOFARM LOGIC
-- ==========================================
task.spawn(function()
    while task.wait(0.2) do -- Fast check loop
        if AutoRedeemEnabled and LocalPlayer.Character then
            local char = LocalPlayer.Character
            local hum = char:FindFirstChildOfClass("Humanoid")
            local backpack = LocalPlayer:FindFirstChild("Backpack")
            local dataFolder = LocalPlayer:FindFirstChild("Data")
            local inventory = dataFolder and dataFolder:FindFirstChild("Inventory")

            if hum then
                for formattedName, _ in pairs(TargetItems) do
                    local itemFound = false

                    -- 1. Check Character (already holding it)
                    for _, item in ipairs(char:GetChildren()) do
                        if item:IsA("Tool") and formatString(item.Name) == formattedName then
                            item:Activate() 
                            VirtualUser:ClickButton1(Vector2.new(0,0)) 
                            itemFound = true
                            break 
                        end
                    end
                    
                    -- 2. Check Backpack (needs equipping)
                    if not itemFound and backpack then
                        for _, item in ipairs(backpack:GetChildren()) do
                            if item:IsA("Tool") and formatString(item.Name) == formattedName then
                                hum:EquipTool(item)
                                task.wait(0.2) 
                                item:Activate() 
                                VirtualUser:ClickButton1(Vector2.new(0,0))
                                itemFound = true
                                break 
                            end
                        end
                    end

                    -- 3. Check Inventory (needs withdrawing)
                    if not itemFound and inventory then
                        for _, invItem in ipairs(inventory:GetChildren()) do
                            if formatString(invItem.Name) == formattedName then
                                local qty = invItem:FindFirstChild("Quantity")
                                if qty and qty.Value > 0 then
                                    pcall(function()
                                        -- Fire the specific withdraw remote with the exact server item name
                                        ReplicatedStorage.Remotes.ItemStorage:FireServer("Withdraw", invItem.Name, 1)
                                    end)
                                    task.wait(0.2) -- Give server a tiny bit of time to move it to the backpack
                                end
                                break
                            end
                        end
                    end
                end
            end
        end
    end
end)
